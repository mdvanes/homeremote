{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "module": "esnext",
        "moduleResolution": "bundler",
        "types": [
            "node",
            "@nx/react/typings/cssmodule.d.ts",
            "@nx/react/typings/image.d.ts"
        ],
        "emitDecoratorMetadata": true,
        "target": "es2021"
    },
    "exclude": [
        "**/setupTests.ts",
        "**/*.spec.ts",
        "**/*.test.ts",
        "vite.config.ts"
    ],
    "include": ["**/*.ts"]
}
